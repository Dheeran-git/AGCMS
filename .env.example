# ============================================================
# AGCMS Environment Variables — PLACEHOLDER TEMPLATE
#
# This file is committed to git. DO NOT paste real secrets here.
# Copy to a local `.env` (gitignored) and fill in real values:
#
#   cp .env.example .env
#
# Production clusters pull these from AWS Secrets Manager via the
# External Secrets Operator (see k8s/external-secrets/README.md)
# or from Sealed Secrets (see k8s/sealed-secrets/README.md). The
# `.env` file is strictly for local `docker compose` development.
# ============================================================

# --- Required (no default — startup fails if unset) ---

# HMAC-SHA256 key for per-row audit signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AGCMS_SIGNING_KEY=<generate-with-token_hex(32)>

# HMAC-SHA256 key for nightly Merkle-root anchoring (separate from
# the row key so a row-key compromise doesn't invalidate anchors).
AGCMS_ANCHOR_KEY=<generate-with-token_hex(32)>

# JWT signing key for dashboard + API auth. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=<generate-with-token_urlsafe(48)>

# Groq API key — free tier at https://console.groq.com
GROQ_API_KEY=<your-groq-api-key>

# --- Optional LLM providers (leave blank to disable) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# --- Optional SSO (leave blank if not using WorkOS yet) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# --- Datastore creds (local compose only) ---
POSTGRES_PASSWORD=<set-a-strong-value>
REDIS_PASSWORD=<set-a-strong-value>

# --- Envelope encryption (local dev; prod uses AWS/GCP KMS) ---
# 32-byte base64-encoded AES key for the local KMS abstraction.
AGCMS_KMS_LOCAL_KEY=<generate-with-openssl-rand-base64-32>

# --- Behaviour knobs (safe defaults) ---
AGCMS_SPACY_MODEL=en_core_web_sm   # swap to en_core_web_trf in prod
AGCMS_ENV=development
