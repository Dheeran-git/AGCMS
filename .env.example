# ============================================================
# AGCMS Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Required ---

# HMAC-SHA256 signing key for audit logs (RULE 4: must not be empty)
AGCMS_SIGNING_KEY=your-audit-log-signing-key-here

# Groq API key (free tier: https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# --- Optional (defaults shown) ---

# PostgreSQL
POSTGRES_PASSWORD=secret

# Redis
REDIS_PASSWORD=secret

# spaCy model: en_core_web_sm (dev, fast) or en_core_web_trf (prod, accurate)
AGCMS_SPACY_MODEL=en_core_web_sm

# Environment
AGCMS_ENV=development

# JWT signing key for dashboard auth
JWT_SECRET_KEY=dev-jwt-secret-change-me
