{
  "name": "@agcms/sdk",
  "version": "0.1.1",
  "description": "Official TypeScript SDK for AGCMS — AI Governance & Compliance Monitoring",
  "license": "Apache-2.0",
  "homepage": "https://agcms-six.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dheeran-git/AGCMS.git",
    "directory": "sdk/typescript"
  },
  "bugs": {
    "url": "https://github.com/Dheeran-git/AGCMS/issues"
  },
  "keywords": [
    "agcms",
    "llm",
    "governance",
    "compliance",
    "openai",
    "audit",
    "pii"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
